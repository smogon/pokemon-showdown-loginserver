{
  "name": "pokemon-showdown-login",
  "version": "0.1.0",
  "homepage": "https://pokemonshowdown.com",
  "license": "AGPL-3.0",
  "main": "./.dist/src/index.js",
  "scripts": {
    "lint": "eslint --cache --max-warnings 0",
    "build": "npx tsc",
    "run": "npx tsc && node .dist/src/",
    "start": "npx tsc && npx pm2 start loginserver",
    "test": "npm run lint && npx tsc && node --test .dist/src/test/*.test.js",
    "reload": "npx tsc && npx pm2 reload loginserver",
    "stop": "npx pm2 stop loginserver"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "google-auth-library": "^10.9.0",
    "mysql2": "^3.23.0",
    "pg": "^8.22.0",
    "pm2": "^7.0.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^4.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "nodemailer": "^6.6.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  },
  "private": true
}
